# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# Google Gemini API key (for book scanning)
GEMINI_API_KEY=

# Your deployed app URL — used for invite links and CORS (no trailing slash)
APP_URL=http://localhost:3000

# Turso hosted database — leave blank to use a local SQLite file in development
# Sign up free at https://turso.tech
TURSO_URL=
TURSO_AUTH_TOKEN=
